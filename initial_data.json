: 4, "fields": {"title": "Mathematics", "slug": "mathematics"}}, {"model": "courses.subject", "pk": 5, "fields": {"title": "Physics", "slug": "physics"}}, {"model": "courses.subject", "pk": 6, "fields": {"title": "Biology", "slug": "biology"}}, {"model": "courses.subject", "pk": 7, "fields": {"title": "Computer Science", "slug": "computer-science"}}, {"model": "courses.subject", "pk": 8, "fields": {"title": "History", "slug": "history"}}, {"model": "courses.course", "pk": 1, "fields": {"owner": 2, "subject": 4, "title": "Calculus", "slug": "calculus", "overview": "Excellent foundational course. Clearly explains how change works in continuous systems. The exercises are challenging but rewarding.", "created": "2026-07-10T09:25:08.459Z", "learners": [3]}}, {"model": "courses.course", "pk": 2, "fields": {"owner": 2, "subject": 4, "title": "Linear Algebra", "slug": "linear-algebra", "overview": "A bit abstract at first, but incredibly useful for data science and engineering. The instructor breaks down complex topics nicely.", "created": "2026-07-10T09:28:29.940Z", "learners": [3]}}, {"model": "courses.course", "pk": 3, "fields": {"owner": 2, "subject": 5, "title": "Classical Mechanics", "slug": "classical-mechanics", "overview": "A classic must-take course. The balance between theory and problem-solving is perfect for beginners.", "created": "2026-07-10T09:31:20.632Z", "learners": [3]}}, {"model": "courses.course", "pk": 4, "fields": {"owner": 2, "subject": 5, "title": "Thermodynamics", "slug": "thermodynamics", "overview": "Engaging and practical. Great for understanding engines, refrigerators, and even weather patterns.", "created": "2026-07-11T05:16:54.480Z", "learners": [3]}}, {"model": "courses.course", "pk": 5, "fields": {"owner": 2, "subject": 6, "title": "Genetics", "slug": "genetics", "overview": "Fascinating and up-to-date. Includes recent CRISPR developments. The quizzes really test your understanding.", "created": "2026-07-11T05:18:10.596Z", "learners": []}}, {"model": "courses.course", "pk": 6, "fields": {"owner": 2, "subject": 6, "title": "Ecology", "slug": "ecology", "overview": "Eye-opening course about interconnected ecosystems. Field data examples make it very applied.", "created": "2026-07-11T05:19:42.124Z", "learners": [3]}}, {"model": "courses.course", "pk": 7, "fields": {"owner": 2, "subject": 8, "title": "Ancient Civilizations", "slug": "ancient-civilizations", "overview": "A wonderful journey through early human societies. Art, architecture, and governance are all well integrated.", "created": "2026-07-11T05:21:10.372Z", "learners": [3]}}, {"model": "courses.course", "pk": 8, "fields": {"owner": 2, "subject": 7, "title": "Data Structures", "slug": "data-structures", "overview": "Absolutely essential for any developer. The code examples are clean, and the performance comparisons are practical.", "created": "2026-07-11T05:23:43.830Z", "learners": [3]}}, {"model": "courses.course", "pk": 9, "fields": {"owner": 2, "subject": 7, "title": "Operating Systems", "slug": "operating-systems", "overview": "Tough but hugely rewarding. You’ll truly understand how your computer manages memory, files, and processes.", "created": "2026-07-11T05:24:54.835Z", "learners": [3]}}, {"model": "courses.module", "pk": 1, "fields": {"course": 1, "title": "Limits and Continuity", "description": "Great introduction to the core idea of approaching values. The graphical examples make abstract concepts tangible.", "order": 0}}, {"model": "courses.module", "pk": 2, "fields": {"course": 1, "title": "Derivatives and Applications", "description": "Well-structured with real-world physics problems. The step-by-step derivations help build intuition.", "order": 1}}, {"model": "courses.module", "pk": 3, "fields": {"course": 2, "title": "Matrix Operations", "description": "Covers addition, multiplication, and inverses thoroughly. Plenty of practice problems with solutions.", "order": 0}}, {"model": "courses.module", "pk": 4, "fields": {"course": 2, "title": "Eigenvalues and Eigenvectors", "description": "The most challenging part of the course, but the visualisations make it click.", "order": 1}}, {"model": "courses.module", "pk": 5, "fields": {"course": 3, "title": "Newton’s Laws of Motion", "description": "Crisp explanations of inertia, force, and acceleration. The free-body diagram tutorials are exceptionally clear.", "order": 0}}, {"model": "courses.module", "pk": 6, "fields": {"course": 3, "title": "Work, Energy, and Power", "description": "Connects math to everyday situations (like lifting weights or driving a car). The conservation examples are memorable.", "order": 1}}, {"model": "courses.module", "pk": 7, "fields": {"course": 4, "title": "Heat and Energy Transfer", "description": "Covers conduction, convection, and radiation with excellent lab simulations. Easy to follow.", "order": 0}}, {"model": "courses.module", "pk": 8, "fields": {"course": 4, "title": "Entropy and the Second Law", "description": "A mind-bending module, but the instructor uses funny analogies that make entropy less intimidating.", "order": 1}}, {"model": "courses.module", "pk": 9, "fields": {"course": 5, "title": "DNA Replication and Repair", "description": "Detailed animations of helicase and polymerase in action. The repair mechanisms are explained with medical relevance.", "order": 0}}, {"model": "courses.module", "pk": 10, "fields": {"course": 5, "title": "Gene Expression and Regulation", "description": "Clear breakdown of transcription and translation. The operon models are taught better than in most textbooks.", "order": 1}}, {"model": "courses.module", "pk": 11, "fields": {"course": 6, "title": "Ecosystem Dynamics", "description": "Great coverage of food webs, energy pyramids, and nutrient cycles. The case studies (e.g., Yellowstone) are captivating.", "order": 0}}, {"model": "courses.module", "pk": 12, "fields": {"course": 6, "title": "Population Growth Models", "description": "Uses simple math to predict species growth. The carrying capacity and logistic model sections are particularly strong.", "order": 1}}, {"model": "courses.module", "pk": 13, "fields": {"course": 7, "title": "Roman Empire", "description": "Covers the Republic, Empire, and fall. The sections on Roman law and engineering are particularly insightful.", "order": 0}}, {"model": "courses.module", "pk": 14, "fields": {"course": 7, "title": "Ancient Greece", "description": "Philosophy, democracy, and mythology are woven together nicely. The comparisons with Persia add great context.", "order": 1}}, {"model": "courses.module", "pk": 15, "fields": {"course": 8, "title": "Linked Lists and Trees", "description": "Great visual diagrams. The traversal algorithms (preorder, inorder, postorder) are explained step by step.", "order": 0}}, {"model": "courses.module", "pk": 16, "fields": {"course": 8, "title": "Hash Tables and Heaps", "description": "Excellent real-world use cases (dictionaries, priority queues). The collision resolution strategies are crystal clear.", "order": 1}}, {"model": "courses.module", "pk": 17, "fields": {"course": 9, "title": "Process Scheduling", "description": "Covers FCFS, SJF, round-robin, and priority scheduling with handy Gantt charts. Very exam-friendly.", "order": 0}}, {"model": "courses.module", "pk": 18, "fields": {"course": 9, "title": "Memory Management and Paging", "description": "Virtual memory, segmentation, and page replacement algorithms (LRU, FIFO) are taught with interactive simulations.", "order": 1}}, {"model": "courses.content", "pk": 1, "fields": {"module": 1, "content_type": 14, "object_id": 1, "order": 0}}, {"model": "courses.content", "pk": 2, "fields": {"module": 1, "content_type": 14, "object_id": 2, "order": 1}}, {"model": "courses.content", "pk": 3, "fields": {"module": 1, "content_type": 14, "object_id": 3, "order": 2}}, {"model": "courses.content", "pk": 4, "fields": {"module": 2, "content_type": 14, "object_id": 4, "order": 0}}, {"model": "courses.content", "pk": 5, "fiel